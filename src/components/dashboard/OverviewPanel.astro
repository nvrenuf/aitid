---
import MetricsStrip from './MetricsStrip.astro';

const {
  initialStats,
  overviewPosture,
  overviewPriority,
  overviewStatus,
  overviewUpdated,
} = Astro.props;

const overviewFilters = [
  { value: 'all', label: 'All', active: true },
  { value: 'critical', label: 'Critical' },
  { value: 'high', label: 'High' },
  { value: 'medium', label: 'Medium' },
  { value: 'supply-chain', label: 'Supply chain' },
  { value: 'jailbreak', label: 'Jailbreak' },
  { value: 'data-exfil', label: 'Data exfil' },
];

const initialStatsJson = JSON.stringify(initialStats);
---

<div class="panel active" id="panel-overview">
  <div id="overview-layout" style="display:flex;flex:1;min-height:0;overflow:hidden">
    <div class="feed-col" id="overview-feed-col" style="flex:1;min-width:0;overflow-y:auto;border-right:none">
      <section class="overview-frame">
        <div class="overview-hero">
          <div class="overview-stage">
            <div class="overview-copy">
              <div class="overview-kicker">Overview</div>
              <div class="overview-title">Current AI threat posture.</div>
              <p>
                Review posture, queue pressure, and collection state, then move into the watchlist.
              </p>
            </div>

            <div class="overview-pills">
              <span class="overview-pill"><strong>Status</strong> <span id="overview-status">{overviewStatus}</span></span>
              <span class="overview-pill"><strong>Updated</strong> <span id="overview-updated">{overviewUpdated}</span></span>
            </div>

            <MetricsStrip initialStats={initialStats} />
          </div>

          <div class="overview-hero-rail">
            <div class="overview-card primary">
              <div class="sb-title">Priority posture</div>
              <p>{overviewPosture}</p>
            </div>
            <div class="overview-card">
              <div class="sb-title">Executive focus</div>
              <p>{overviewPriority}</p>
              <div class="overview-grid overview-grid-compact">
                <div class="overview-stat">
                  <div class="sb-title">Tracked queue</div>
                  <span>{initialStats.totalThreats} items</span>
                </div>
                <div class="overview-stat">
                  <div class="sb-title">Collection</div>
                  <span>{overviewStatus}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <div class="filterbar">
        <span class="fl">Scope</span>
        {
          overviewFilters.map((filter) => (
            <button class:list={['fpill', filter.active && 'active']} data-f={filter.value}>
              {filter.label}
            </button>
          ))
        }
      </div>

      <div class="shdr"><span>Active watchlist</span><span>severity + blended score</span></div>

      <div id="overview-feed">
        <div class="loading-shell" aria-live="polite" aria-label="Loading threat feed">
          <div class="loading-card">
            <div class="loading-card-head">
              <div class="loading-pill-row">
                <span class="loading-pill"></span>
                <span class="loading-pill"></span>
                <span class="loading-pill loading-pill-wide"></span>
              </div>
              <span class="loading-mini-card"></span>
            </div>
            <div class="loading-stack">
              <span class="loading-line loading-line-lg"></span>
              <span class="loading-line loading-line-md"></span>
            </div>
            <div class="loading-grid">
              <span class="loading-panel"></span>
              <span class="loading-panel"></span>
            </div>
          </div>
          <div class="loading-card">
            <div class="loading-card-head">
              <div class="loading-pill-row">
                <span class="loading-pill"></span>
                <span class="loading-pill"></span>
              </div>
              <span class="loading-mini-card"></span>
            </div>
            <div class="loading-stack">
              <span class="loading-line loading-line-lg"></span>
              <span class="loading-line loading-line-sm"></span>
            </div>
            <div class="loading-grid">
              <span class="loading-panel"></span>
              <span class="loading-panel"></span>
            </div>
          </div>
          <div class="loading-copy">Preparing the current watchlist.</div>
        </div>
      </div>

      <script id="overview-initial-stats" type="application/json" set:html={initialStatsJson}></script>
    </div>

    <div class="resize-handle" id="sidebar-resize-handle"></div>

    <div class="sidebar" id="overview-sidebar" style="width:260px;min-width:160px;max-width:520px;overflow-y:auto;flex-shrink:0">
      <div class="sb-block executive">
        <div class="sb-title">Analyst context</div>
        <div class="sb-list">
          <div class="sb-list-item">
            <strong>{overviewStatus}</strong>
            <span>Cadence remains steady across the current feed.</span>
          </div>
          <div class="sb-list-item">
            <strong>{initialStats.modelsAffected} model families in scope</strong>
            <span>Model concentration remains visible in the side rail.</span>
          </div>
        </div>
      </div>
      <div class="sb-block">
        <div class="sb-title">Threat volume - 8w</div>
        <div class="tl" id="sb-tl"></div>
        <div class="tll" id="sb-tll"></div>
      </div>
      <div class="sb-block">
        <div class="sb-title">Exposure by model</div>
        <div id="sb-models"></div>
      </div>
      <div class="sb-block">
        <div class="sb-title">Vector x model</div>
        <div id="sb-matrix"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .overview-frame {
    display: grid;
    gap: 16px;
    padding-bottom: 16px;
  }

  .overview-hero {
    display: grid;
    gap: 16px;
    grid-template-columns: minmax(0, 1.18fr) minmax(260px, 0.82fr);
    align-items: start;
  }

  .overview-stage,
  .overview-hero-rail {
    display: grid;
    gap: 12px;
  }

  .overview-stage {
    gap: 14px;
  }

  .overview-copy p {
    max-width: 42ch;
  }

  .overview-hero-rail .overview-card {
    min-height: 0;
  }

  .overview-grid-compact {
    margin-top: 12px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .sb-block.executive {
    background: linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.02));
  }

  @media (max-width: 1380px) {
    #overview-layout {
      flex-direction: column;
      overflow: visible;
    }

    #overview-feed-col {
      overflow-y: visible !important;
    }

    #overview-sidebar {
      width: auto !important;
      min-width: 0 !important;
      max-width: none !important;
      overflow-y: visible !important;
      border-top: 1px solid var(--border);
      padding-top: 12px;
    }

    #sidebar-resize-handle {
      display: none;
    }
  }

  @media (max-width: 1180px) {
    .overview-hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 960px) {
    .overview-hero {
      grid-template-columns: 1fr;
    }

    .overview-grid-compact {
      grid-template-columns: 1fr;
    }
  }
</style>
