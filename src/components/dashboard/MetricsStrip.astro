---
const { initialStats } = Astro.props;

const metrics = [
  {
    label: 'Critical active',
    note: 'Leadership visibility',
    value: initialStats.activeCritical,
    valueId: 'm-crit',
    valueClass: 'crit',
    deltaId: 'm-crit-d',
    deltaClass: 'up',
  },
  {
    label: 'Tracked queue',
    note: 'Current corpus',
    value: initialStats.totalThreats,
    valueId: 'm-total',
    deltaId: 'm-total-d',
  },
  {
    label: 'New in seven days',
    note: 'Fresh pressure',
    value: initialStats.newThisWeek,
    valueId: 'm-week',
    valueClass: 'amber',
    deltaId: 'm-week-d',
  },
  {
    label: 'Models in scope',
    note: 'Distinct model tags',
    value: initialStats.modelsAffected,
    valueId: 'm-models',
    valueClass: 'info',
    deltaId: 'm-models-d',
    deltaClass: 'dn',
  },
];
---

<div class="overview-kpi-band" id="metrics-strip">
  {
    metrics.map((metric) => (
      <div class:list={['overview-kpi-card', metric.valueClass]}>
        <div class="overview-kpi-head">
          <div class="m-label">{metric.label}</div>
          <div class="overview-kpi-note">{metric.note}</div>
        </div>
        <div class="overview-kpi-body">
          <div class:list={['overview-kpi-value', metric.valueClass]} id={metric.valueId}>
            {metric.value}
          </div>
          <div class:list={['overview-kpi-delta', metric.deltaClass]} id={metric.deltaId}></div>
        </div>
      </div>
    ))
  }
</div>

<style>
  .overview-kpi-band {
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .overview-kpi-card {
    min-height: 122px;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.015));
    box-shadow: var(--shadow-soft);
    display: grid;
    gap: 14px;
    align-content: space-between;
  }

  .overview-kpi-card.crit {
    background: linear-gradient(180deg, rgba(255,122,122,.14), rgba(255,122,122,.05));
    border-color: rgba(255,122,122,.2);
  }

  .overview-kpi-head {
    display: grid;
    gap: 6px;
  }

  .overview-kpi-note {
    color: var(--txt3);
    font-size: 12px;
    line-height: 1.4;
  }

  .overview-kpi-body {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 10px;
  }

  .overview-kpi-value {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 38px);
    line-height: 0.95;
    letter-spacing: -0.05em;
  }

  .overview-kpi-value.crit {
    color: var(--crit);
  }

  .overview-kpi-value.amber {
    color: var(--med);
  }

  .overview-kpi-value.info {
    color: var(--info);
  }

  .overview-kpi-delta {
    color: var(--txt3);
    font-size: 11px;
    font-weight: 700;
    text-align: right;
    max-width: 10ch;
    line-height: 1.4;
  }

  .overview-kpi-delta.up {
    color: var(--crit);
  }

  .overview-kpi-delta.dn {
    color: var(--low);
  }

  @media (max-width: 1280px) {
    .overview-kpi-band {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .overview-kpi-band {
      grid-template-columns: 1fr;
    }
  }
</style>
