---
import { getThreatDetailHref } from '../../lib/threats-utils.js';
import { projectThreatMapAnchor } from '../../lib/threat-map-projection.js';

const { dataset } = Astro.props;

const initialRegion = dataset.regions[0] ?? null;

const severityOptions = [...new Set(dataset.points.map((point) => point.severity))];
const modelOptions = [...new Set(dataset.points.flatMap((point) => point.models))].sort();
const vectorOptions = [...new Set(dataset.points.flatMap((point) => point.vectors))].sort();
const initialDataset = JSON.stringify(dataset);
const fallbackRegions = dataset.regions.slice(0, 4);
---

<section class="page-panel threat-map-shell">
  <div class="threat-map-heading">
    <div class="page-copy">
      <span class="page-eyebrow">Observed geography only</span>
      <div>
        <div class="page-kicker">Threat Map</div>
        <h1 class="page-headline">Regional posture from observed infrastructure and exposure geography.</h1>
      </div>
      <p>
        Threat Map stays conservative: approximate regional anchors, visible coverage limits, and no claims
        about actor origin, customer geography, or live attack traffic. Filters only narrow the current
        mapped corpus; they do not invent new geography.
      </p>
    </div>
    <div class="threat-map-stats">
      <div class="info-card">
        <span>Mapped regions</span>
        <strong>{dataset.coverage.mappedRegionCount}</strong>
        <p>{dataset.coverage.pointCount} map observations are currently available for this non-production corpus.</p>
      </div>
      <div class="info-card">
        <span>Mapped threats</span>
        <strong>{dataset.coverage.mappedThreatCount}</strong>
        <p>{dataset.coverage.unmappedThreatCount} tracked threats remain intentionally unmapped until defensible geography exists.</p>
      </div>
      <div class="info-card">
        <span>Meaning</span>
        <strong>Observed infrastructure / exposure</strong>
        <p>Every map node points to coarse regional context only.</p>
      </div>
    </div>
  </div>

  <div class="threat-map-filterbar">
    <div>
      <div class="page-kicker">Operational filters</div>
      <strong id="threat-map-filter-count">{dataset.coverage.pointCount} mapped observations</strong>
    </div>
    <div class="threat-map-filter-controls">
      <label class="threat-map-filter">
        <span>Severity</span>
        <select id="threat-map-filter-severity">
          <option value="">All severities</option>
          {severityOptions.map((severity) => <option value={severity}>{severity}</option>)}
        </select>
      </label>
      <label class="threat-map-filter">
        <span>Model</span>
        <select id="threat-map-filter-model">
          <option value="">All models</option>
          {modelOptions.map((model) => <option value={model}>{model}</option>)}
        </select>
      </label>
      <label class="threat-map-filter">
        <span>Vector</span>
        <select id="threat-map-filter-vector">
          <option value="">All vectors</option>
          {vectorOptions.map((vector) => <option value={vector}>{vector}</option>)}
        </select>
      </label>
    </div>
    <div class="surface-chips" id="threat-map-active-filters">
      <span class="future-chip">All mapped threats</span>
      <span class="future-chip">{dataset.coverage.unmappedThreatCount} unmapped remain</span>
    </div>
  </div>

  <div class="threat-map-workspace">
    <div class="threat-map-stage-wrap">
      <div class="threat-map-stage" id="threat-map-stage" data-map-state="ready">
        <svg class="threat-map-backdrop" viewBox="0 0 1000 520" aria-hidden="true">
          <defs>
            <linearGradient id="oceanFade" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="rgba(125,196,255,0.18)" />
              <stop offset="100%" stop-color="rgba(125,196,255,0.03)" />
            </linearGradient>
          </defs>
          <rect x="0" y="0" width="1000" height="520" rx="28" fill="url(#oceanFade)" />
          <g class="threat-map-grid">
            <line x1="200" y1="0" x2="200" y2="520" />
            <line x1="400" y1="0" x2="400" y2="520" />
            <line x1="600" y1="0" x2="600" y2="520" />
            <line x1="800" y1="0" x2="800" y2="520" />
            <line x1="0" y1="130" x2="1000" y2="130" />
            <line x1="0" y1="260" x2="1000" y2="260" />
            <line x1="0" y1="390" x2="1000" y2="390" />
          </g>
          <g class="threat-map-land">
            <path d="M88 128l120-44 112 18 44 56-26 44-78 40-26 76-96 8-52-72 16-72 50-54z" />
            <path d="M372 102l102-22 92 14 82 42 16 56-30 36-64 16-40 44-48 8-70-48-42-76 2-70z" />
            <path d="M610 128l88-24 128 30 78 50-18 52-54 24-18 48-78 34-90-24-46-66 10-76z" />
            <path d="M790 338l90-26 74 26 20 42-36 58-84 26-72-18-16-52 24-56z" />
          </g>
        </svg>

        <div id="threat-map-nodes">
          {
            dataset.regions.map((region) => {
              const point = projectThreatMapAnchor(region.anchor);
              const size = Math.min(72, 28 + region.threatCount * 8);
              return (
                <button
                  type="button"
                  class:list={['map-region-node', initialRegion?.regionKey === region.regionKey && 'active']}
                  data-region-node={region.regionKey}
                  style={`left:${point.x}%;top:${point.y}%;width:${size}px;height:${size}px;`}
                  aria-pressed={initialRegion?.regionKey === region.regionKey ? 'true' : 'false'}
                >
                  <span class="map-region-count">{region.threatCount}</span>
                  <span class="map-region-label">{region.regionName}</span>
                </button>
              );
            })
          }
        </div>

        <section class="threat-map-stage-fallback" id="threat-map-stage-fallback" hidden>
          <div class="page-kicker">Regional fallback</div>
          <h2 id="threat-map-stage-fallback-title">Regional coverage remains available</h2>
          <p id="threat-map-stage-fallback-copy">
            If the projected map visualization degrades, the current regional coverage summary stays available here instead of leaving the page blank.
          </p>
          <div class="page-list" id="threat-map-stage-fallback-list">
            {
              fallbackRegions.map((region) => (
                <div class="page-list-item">
                  <strong>{region.regionName}</strong>
                  <p>{region.threatCount} tracked threats · {region.pointCount} mapped observations · {region.anchor.label}</p>
                </div>
              ))
            }
          </div>
        </section>
      </div>

      <div class="info-card-grid threat-map-notes">
        {
          dataset.limitations.map((limitation) => (
            <div class="info-card">
              <span>Constraint</span>
              <p>{limitation}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="threat-map-detail-stack">
      <div id="threat-map-region-details">
        {
          initialRegion ? (
            <section class="threat-map-detail active">
              <div class="threat-map-detail-head">
                <div>
                  <div class="page-kicker">Regional detail</div>
                  <h2>{initialRegion.regionName}</h2>
                </div>
                <span class="page-eyebrow">{initialRegion.threatCount} tracked threats</span>
              </div>

              <div class="info-card-grid">
                <div class="info-card">
                  <span>Precision</span>
                  <strong>{initialRegion.precisions.join(', ')}</strong>
                  <p>{initialRegion.anchor.label} is an approximate map anchor for this region.</p>
                </div>
                <div class="info-card">
                  <span>Dominant vectors</span>
                  <strong>{initialRegion.dominantVectors.join(', ')}</strong>
                  <p>Vectors reflect the mapped threats aggregated into this regional summary.</p>
                </div>
                <div class="info-card">
                  <span>Affected models</span>
                  <strong>{initialRegion.affectedModels.join(', ')}</strong>
                  <p>Model tags are pulled directly from mapped threats in this region.</p>
                </div>
                <div class="info-card">
                  <span>Observation count</span>
                  <strong>{initialRegion.pointCount}</strong>
                  <p>Multiple observations can roll up into the same region when the underlying signal is coarse.</p>
                </div>
              </div>

              <div class="threat-map-section">
                <div class="page-kicker">Top threats</div>
                <div class="page-list">
                  {
                    initialRegion.topThreats.map((threat) => (
                      <div class="page-list-item">
                        <strong><a class="drawer-link" href={getThreatDetailHref({ title: threat.title })}>{threat.title}</a></strong>
                        <p>
                          Severity {threat.severity} · blended score {threat.score.toFixed(1)}
                        </p>
                      </div>
                    ))
                  }
                </div>
              </div>

              <div class="threat-map-section">
                <div class="page-kicker">Observation notes</div>
                <div class="page-list">
                  {
                    dataset.points
                      .filter((point) => point.regionKey === initialRegion.regionKey)
                      .map((point) => (
                        <div class="page-list-item">
                          <strong><a class="drawer-link" href={getThreatDetailHref({ title: point.threatTitle })}>{point.threatTitle}</a></strong>
                          <p>
                            {point.summary}
                            <br />
                            Scope: {point.scope} · Quality: {point.sourceQuality}
                          </p>
                        </div>
                      ))
                  }
                </div>
              </div>
            </section>
          ) : null
        }
      </div>

      <section class="page-list threat-map-unmapped" id="threat-map-unmapped">
        <div class="page-kicker">Unmapped coverage</div>
        <div class="page-list-item">
          <strong>{dataset.coverage.unmappedThreatCount} threats remain off-map</strong>
          <p>
            Threats without a defensible geography observation stay out of the map surface. The reason
            categories below explain why the current records remain unmapped instead of showing raw IDs alone.
          </p>
        </div>
        {
          [...new Map(dataset.unmappedThreats.map((threat) => [threat.reasonCategory, threat])).values()].map((threat) => (
            <div class="page-list-item">
              <strong>{threat.reasonCategory}</strong>
              <p>{threat.reasonDetail}</p>
            </div>
          ))
        }
      </section>
    </div>
  </div>

  <script id="threat-map-dataset" type="application/json" set:html={initialDataset}></script>
</section>

<script>
  import '../../scripts/threat-map-client.js';
</script>

<style>
  .threat-map-shell {
    display: grid;
    gap: 20px;
  }

  .threat-map-heading {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
  }

  .threat-map-stats {
    display: grid;
    gap: 12px;
  }

  .threat-map-filterbar {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.02);
    padding: 18px;
    display: grid;
    gap: 14px;
  }

  .threat-map-filter-controls {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .threat-map-filter {
    display: grid;
    gap: 8px;
    font-size: 12px;
    color: var(--txt2);
    font-weight: 700;
  }

  .threat-map-filter select {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
    color: var(--txt);
    padding: 11px 13px;
    font: inherit;
  }

  .threat-map-workspace {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.2fr) minmax(340px, 0.8fr);
  }

  .threat-map-stage-wrap,
  .threat-map-detail,
  .threat-map-unmapped {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.02);
  }

  .threat-map-stage-wrap {
    padding: 18px;
    display: grid;
    gap: 18px;
  }

  .threat-map-stage {
    position: relative;
    min-height: 520px;
    border: 1px solid rgba(125, 196, 255, 0.14);
    border-radius: 28px;
    overflow: hidden;
    background:
      radial-gradient(circle at top, rgba(125, 196, 255, 0.18), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
  }

  .threat-map-backdrop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  #threat-map-nodes {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .threat-map-grid line {
    stroke: rgba(139, 162, 191, 0.12);
    stroke-width: 1;
  }

  .threat-map-land path {
    fill: rgba(139, 162, 191, 0.12);
    stroke: rgba(139, 162, 191, 0.18);
    stroke-width: 2;
  }

  .map-region-node {
    position: absolute;
    z-index: 3;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    border: 1px solid rgba(125, 196, 255, 0.34);
    background: radial-gradient(circle at 30% 30%, rgba(125, 196, 255, 0.34), rgba(7, 16, 24, 0.9));
    color: var(--txt);
    box-shadow: 0 0 0 10px rgba(125, 196, 255, 0.06), 0 14px 34px rgba(0, 0, 0, 0.3);
    cursor: pointer;
    transition: transform 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease;
  }

  .map-region-node:hover,
  .map-region-node.active {
    transform: translate(-50%, -50%) scale(1.05);
    border-color: rgba(255, 211, 105, 0.46);
    box-shadow: 0 0 0 12px rgba(255, 211, 105, 0.08), 0 18px 40px rgba(0, 0, 0, 0.34);
  }

  .map-region-count,
  .map-region-label {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
  }

  .map-region-count {
    top: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  .map-region-label {
    top: calc(100% + 10px);
    font-size: 11px;
    font-weight: 700;
    color: var(--txt2);
  }

  .threat-map-notes {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .threat-map-stage-fallback {
    position: absolute;
    inset: 18px;
    z-index: 4;
    display: grid;
    align-content: start;
    gap: 14px;
    padding: 22px;
    border: 1px solid rgba(125, 196, 255, 0.2);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(7, 16, 24, 0.92), rgba(7, 16, 24, 0.84)),
      radial-gradient(circle at top, rgba(125, 196, 255, 0.14), transparent 52%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .threat-map-stage[data-map-state='fallback'] .threat-map-backdrop,
  .threat-map-stage[data-map-state='fallback'] #threat-map-nodes {
    opacity: 0.18;
  }

  .threat-map-detail-stack {
    display: grid;
    gap: 16px;
  }

  .threat-map-detail,
  .threat-map-unmapped {
    padding: 18px;
    display: grid;
    gap: 18px;
  }

  .threat-map-detail-head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: start;
  }

  .threat-map-section,
  .threat-map-unmapped-group {
    display: grid;
    gap: 12px;
  }

  @media (max-width: 960px) {
    .threat-map-heading,
    .threat-map-workspace,
    .threat-map-filter-controls,
    .threat-map-notes {
      grid-template-columns: 1fr;
    }
  }
</style>
