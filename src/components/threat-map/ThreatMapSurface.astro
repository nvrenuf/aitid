---
import { getThreatDetailHref } from '../../lib/threats-utils.js';
import { projectThreatMapAnchor } from '../../lib/threat-map-projection.js';
import ProjectedWorldMap from './ProjectedWorldMap.astro';

const { dataset } = Astro.props;

const initialRegion = dataset.regions[0] ?? null;

const severityOptions = [...new Set(dataset.points.map((point) => point.severity))];
const modelOptions = [...new Set(dataset.points.flatMap((point) => point.models))].sort();
const vectorOptions = [...new Set(dataset.points.flatMap((point) => point.vectors))].sort();
const initialDataset = JSON.stringify(dataset);
const fallbackRegions = dataset.regions.slice(0, 4);
---

<section class="page-panel threat-map-shell">
  <div class="threat-map-heading">
    <div class="threat-map-lead">
      <div class="page-copy">
        <span class="page-eyebrow">Observed geography only</span>
        <div>
          <div class="page-kicker">Threat map</div>
          <h1 class="page-headline">Regional posture framed like analysis, not like a demo surface.</h1>
        </div>
        <p>
          ThreatParallax keeps geography conservative: coarse regional anchors, explicit coverage limits,
          and no claim about actor origin, customer geography, or live attack traffic.
        </p>
      </div>

      <div class="surface-chips threat-map-heading-chips">
        <span class="future-chip">observed infrastructure only</span>
        <span class="future-chip">coarse regional anchors</span>
        <span class="future-chip">unmapped records retained</span>
      </div>
    </div>

    <div class="threat-map-stats">
      <div class="info-card">
        <span>Mapped regions</span>
        <strong>{dataset.coverage.mappedRegionCount}</strong>
        <p>Conservative grouping only.</p>
      </div>
      <div class="info-card">
        <span>Mapped threats</span>
        <strong>{dataset.coverage.mappedThreatCount}</strong>
        <p>Only records with defensible location support.</p>
      </div>
      <div class="info-card">
        <span>Unmapped retained</span>
        <strong>{dataset.coverage.unmappedThreatCount}</strong>
        <p>Coverage gaps stay explicit instead of being placed on the map.</p>
      </div>
    </div>
  </div>

  <div class="threat-map-filterbar">
    <div class="threat-map-filter-summary">
      <div class="page-kicker">Filter rail</div>
      <strong id="threat-map-filter-count">{dataset.coverage.pointCount} mapped observations</strong>
      <p>Severity, model, and vector narrow the current corpus only. They do not change map meaning.</p>
    </div>

    <div class="threat-map-filter-controls">
      <label class="threat-map-filter">
        <span>Severity</span>
        <select id="threat-map-filter-severity">
          <option value="">All severities</option>
          {severityOptions.map((severity) => <option value={severity}>{severity}</option>)}
        </select>
      </label>
      <label class="threat-map-filter">
        <span>Model</span>
        <select id="threat-map-filter-model">
          <option value="">All models</option>
          {modelOptions.map((model) => <option value={model}>{model}</option>)}
        </select>
      </label>
      <label class="threat-map-filter">
        <span>Vector</span>
        <select id="threat-map-filter-vector">
          <option value="">All vectors</option>
          {vectorOptions.map((vector) => <option value={vector}>{vector}</option>)}
        </select>
      </label>
    </div>

    <div class="threat-map-filter-rail">
      <div class="surface-chips" id="threat-map-active-filters">
        <span class="future-chip">All mapped threats</span>
        <span class="future-chip">{dataset.coverage.unmappedThreatCount} unmapped remain</span>
      </div>
      <button type="button" class="expand-btn threat-map-reset-btn" id="threat-map-reset-filters">Reset filters</button>
    </div>
  </div>

  <div class="threat-map-workspace">
    <div class="threat-map-stage-wrap">
      <div class="threat-map-stage" id="threat-map-stage" data-map-state="ready">
        <ProjectedWorldMap />

        <div id="threat-map-nodes">
          {
            dataset.regions.map((region) => {
              const point = projectThreatMapAnchor(region.anchor);
              const size = Math.min(72, 28 + region.threatCount * 8);
              return (
                <button
                  type="button"
                  class:list={['map-region-node', initialRegion?.regionKey === region.regionKey && 'active']}
                  data-region-node={region.regionKey}
                  style={`left:${point.x}%;top:${point.y}%;width:${size}px;height:${size}px;`}
                  aria-pressed={initialRegion?.regionKey === region.regionKey ? 'true' : 'false'}
                >
                  <span class="map-region-count">{region.threatCount}</span>
                  <span class="map-region-label">{region.regionName}</span>
                </button>
              );
            })
          }
        </div>

        <div class="threat-map-hovercard" id="threat-map-hovercard" hidden></div>

        <section class="threat-map-stage-fallback" id="threat-map-stage-fallback" hidden>
          <div class="page-kicker">Regional fallback</div>
          <h2 id="threat-map-stage-fallback-title">Regional coverage remains available</h2>
          <p id="threat-map-stage-fallback-copy">
            If the projected map visualization degrades, the current regional summary remains available here.
          </p>
          <div class="page-list" id="threat-map-stage-fallback-list">
            {
              fallbackRegions.map((region) => (
                <div class="page-list-item">
                  <strong>{region.regionName}</strong>
                  <p>{region.threatCount} tracked threats &middot; {region.pointCount} mapped observations &middot; {region.anchor.label}</p>
                </div>
              ))
            }
          </div>
        </section>

        <div class="threat-map-stage-caption">
          <div>
            <span class="page-kicker">Map meaning</span>
            <strong>Regional infrastructure and exposure observations</strong>
            <p>Not actor origin, not customer geography, and not live attack telemetry.</p>
          </div>
          <div class="threat-map-legend">
            <span><span class="threat-map-dot threat-map-dot-critical"></span>higher-pressure cluster</span>
            <span><span class="threat-map-dot threat-map-dot-info"></span>supporting observation</span>
          </div>
        </div>
      </div>

      <div class="info-card-grid threat-map-notes">
        {
          dataset.limitations.map((limitation) => (
            <div class="info-card">
              <span>Constraint</span>
              <p>{limitation}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="threat-map-detail-stack">
      <div id="threat-map-region-details">
        {
          initialRegion ? (
            <section class="threat-map-detail active">
              <div class="threat-map-detail-head">
                <div>
                  <div class="page-kicker">Regional brief</div>
                  <h2>{initialRegion.regionName}</h2>
                  <p class="threat-map-detail-copy">Approximate posture based on the mapped observations currently in scope.</p>
                </div>
                <div class="threat-map-detail-stat">
                  <span>Tracked threats</span>
                  <strong>{initialRegion.threatCount}</strong>
                  <p>{initialRegion.pointCount} mapped observations</p>
                </div>
              </div>

              <div class="threat-map-intel-grid">
                <div class="info-card">
                  <span>Anchor precision</span>
                  <strong>{initialRegion.precisions.join(', ')}</strong>
                  <p>{initialRegion.anchor.label}</p>
                </div>
                <div class="info-card">
                  <span>Dominant vectors</span>
                  <strong>{initialRegion.dominantVectors.join(', ')}</strong>
                  <p>Vector labels remain tied to the filtered mapped threats.</p>
                </div>
              </div>

              <section class="threat-map-section-card">
                <div class="page-kicker">Regional exposure leaders</div>
                <div class="page-list">
                  {
                    initialRegion.topThreats.map((threat) => (
                      <div class="page-list-item">
                        <strong><a class="drawer-link" href={getThreatDetailHref({ title: threat.title })}>{threat.title}</a></strong>
                        <p>Severity {threat.severity} &middot; blended score {threat.score.toFixed(1)}</p>
                      </div>
                    ))
                  }
                </div>
              </section>

              <section class="threat-map-section-card">
                <div class="page-kicker">Observation notes</div>
                <div class="page-list">
                  {
                    dataset.points
                      .filter((point) => point.regionKey === initialRegion.regionKey)
                      .map((point) => (
                        <div class="page-list-item">
                          <strong><a class="drawer-link" href={getThreatDetailHref({ title: point.threatTitle })}>{point.threatTitle}</a></strong>
                          <p>
                            {point.summary}
                            <br />
                            Scope: {point.scope} &middot; Quality: {point.sourceQuality}
                          </p>
                        </div>
                      ))
                  }
                </div>
              </section>
            </section>
          ) : null
        }
      </div>

      <section class="page-list threat-map-unmapped" id="threat-map-unmapped">
        <div class="page-kicker">Unmapped coverage</div>
        <div class="page-list-item">
          <strong>{dataset.coverage.unmappedThreatCount} threats remain off-map</strong>
          <p>Threats stay off-map until defensible geography exists. Reason categories below explain why.</p>
        </div>
        {
          [...new Map(dataset.unmappedThreats.map((threat) => [threat.reasonCategory, threat])).values()].map((threat) => (
            <div class="page-list-item">
              <strong>{threat.reasonCategory}</strong>
              <p>{threat.reasonDetail}</p>
            </div>
          ))
        }
      </section>
    </div>
  </div>

  <script id="threat-map-dataset" type="application/json" set:html={initialDataset}></script>
</section>

<script>
  import '../../scripts/threat-map-client.js';
</script>

<style>
  .threat-map-shell,
  .threat-map-lead,
  .threat-map-stats,
  .threat-map-detail-stack {
    display: grid;
    gap: 18px;
  }

  .threat-map-heading {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.16fr) minmax(320px, 0.84fr);
  }

  .threat-map-heading-chips {
    align-items: center;
  }

  .threat-map-stats {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .threat-map-filterbar {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.015));
    padding: 18px;
    display: grid;
    gap: 16px;
    grid-template-columns: minmax(240px, 0.72fr) minmax(0, 1.28fr);
    align-items: end;
  }

  .threat-map-filter-summary {
    display: grid;
    gap: 8px;
  }

  .threat-map-filter-summary p {
    margin: 0;
    color: var(--txt2);
    max-width: 44ch;
  }

  .threat-map-filter-controls {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .threat-map-filter-rail {
    grid-column: 1 / -1;
    display: flex;
    gap: 12px;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
  }

  .threat-map-filter {
    display: grid;
    gap: 8px;
    font-size: 12px;
    color: var(--txt2);
    font-weight: 700;
  }

  .threat-map-filter select {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(255,255,255,.03);
    color: var(--txt);
    padding: 11px 13px;
    font: inherit;
  }

  .threat-map-workspace {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.32fr) minmax(360px, 0.82fr);
    align-items: start;
  }

  .threat-map-stage-wrap,
  .threat-map-detail,
  .threat-map-unmapped {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.015));
  }

  .threat-map-stage-wrap {
    padding: 18px;
    display: grid;
    gap: 18px;
  }

  .threat-map-stage {
    position: relative;
    min-height: 540px;
    border: 1px solid rgba(125, 196, 255, 0.14);
    border-radius: 28px;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 18%, rgba(125, 196, 255, 0.12), transparent 28%),
      linear-gradient(180deg, rgba(13, 22, 34, 0.98), rgba(9, 16, 25, 0.98));
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,.04),
      inset 0 -80px 120px rgba(0,0,0,.2);
  }

  .threat-map-backdrop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  :global(#threat-map-nodes) {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .projected-world-map .world-grid line {
    stroke: rgba(170, 195, 220, 0.12);
    stroke-dasharray: 2 10;
  }

  :global(.map-region-node) {
    position: absolute;
    z-index: 3;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    border: 1px solid rgba(125, 196, 255, 0.34);
    background: radial-gradient(circle at 30% 30%, rgba(125, 196, 255, 0.34), rgba(7, 16, 24, 0.9));
    color: var(--txt);
    box-shadow: 0 0 0 10px rgba(125, 196, 255, 0.05), 0 14px 34px rgba(0, 0, 0, 0.3);
    cursor: pointer;
    transition: transform 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease;
  }

  :global(.map-region-node:hover),
  :global(.map-region-node.active),
  :global(.map-region-node.preview) {
    transform: translate(-50%, -50%) scale(1.05);
    border-color: rgba(255, 211, 105, 0.4);
    box-shadow: 0 0 0 12px rgba(255, 211, 105, 0.07), 0 18px 40px rgba(0, 0, 0, 0.34);
  }

  .threat-map-hovercard {
    position: absolute;
    z-index: 5;
    min-width: 190px;
    max-width: 240px;
    padding: 14px 16px;
    border: 1px solid rgba(125, 196, 255, 0.18);
    border-radius: 18px;
    background: rgba(6, 11, 18, 0.92);
    backdrop-filter: blur(16px);
    box-shadow: 0 20px 44px rgba(0, 0, 0, 0.34);
    pointer-events: none;
    display: grid;
    gap: 8px;
  }

  .threat-map-hovercard[hidden] {
    display: none;
  }

  .threat-map-hovercard strong {
    font-size: 15px;
    line-height: 1.2;
  }

  .threat-map-hovercard p {
    margin: 0;
    color: var(--txt2);
    font-size: 12px;
    line-height: 1.5;
  }

  .threat-map-hover-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    color: var(--txt3);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
  }

  :global(.map-region-count),
  :global(.map-region-label) {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
  }

  :global(.map-region-count) {
    top: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  :global(.map-region-label) {
    top: calc(100% + 10px);
    font-size: 11px;
    font-weight: 700;
    color: var(--txt2);
  }

  .threat-map-stage-fallback {
    position: absolute;
    inset: 18px;
    z-index: 4;
    display: grid;
    align-content: start;
    gap: 14px;
    padding: 22px;
    border: 1px solid rgba(125, 196, 255, 0.2);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(7, 16, 24, 0.92), rgba(7, 16, 24, 0.84)),
      radial-gradient(circle at top, rgba(125, 196, 255, 0.14), transparent 52%);
    box-shadow: inset 0 1px 0 rgba(255,255,255,.03);
  }

  .threat-map-stage-fallback[hidden] {
    display: none !important;
  }

  .threat-map-stage[data-map-state='fallback'] .threat-map-backdrop,
  .threat-map-stage[data-map-state='fallback'] :global(#threat-map-nodes) {
    opacity: 0.18;
  }

  .threat-map-stage-caption {
    position: absolute;
    left: 18px;
    right: 18px;
    bottom: 18px;
    z-index: 4;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: end;
    padding: 14px 16px;
    border: 1px solid rgba(125, 196, 255, 0.14);
    border-radius: 18px;
    background: rgba(6, 11, 18, 0.74);
    backdrop-filter: blur(12px);
  }

  .threat-map-stage-caption strong {
    display: block;
    font-size: 14px;
  }

  .threat-map-stage-caption p {
    margin: 6px 0 0;
    max-width: 36ch;
    color: var(--txt2);
    font-size: 12px;
  }

  .threat-map-legend {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
    color: var(--txt2);
    font-size: 12px;
  }

  .threat-map-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    display: inline-block;
    margin-right: 6px;
  }

  .threat-map-dot-info {
    background: var(--info);
  }

  .threat-map-dot-critical {
    background: var(--crit);
  }

  .threat-map-notes,
  .threat-map-intel-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .threat-map-detail-stack {
    position: sticky;
    top: 116px;
    align-content: start;
  }

  :global(.threat-map-detail),
  :global(.threat-map-unmapped) {
    padding: 18px;
    display: grid;
    gap: 18px;
  }

  :global(.threat-map-detail-head) {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: start;
  }

  :global(.threat-map-detail-copy) {
    margin: 8px 0 0;
    color: var(--txt2);
    max-width: 40ch;
  }

  :global(.threat-map-detail-stat) {
    min-width: 132px;
    padding: 14px 16px;
    border: 1px solid rgba(125, 196, 255, 0.18);
    border-radius: 18px;
    background: rgba(125, 196, 255, 0.05);
    display: grid;
    gap: 6px;
  }

  :global(.threat-map-detail-stat span) {
    color: var(--txt2);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  :global(.threat-map-detail-stat strong) {
    font-family: var(--font-display);
    font-size: 28px;
    line-height: 1;
  }

  :global(.threat-map-detail-stat p) {
    margin: 0;
    color: var(--txt2);
    font-size: 12px;
  }

  :global(.threat-map-section-card) {
    border: 1px solid rgba(125, 196, 255, 0.14);
    border-radius: 18px;
    background: rgba(255,255,255,.02);
    padding: 16px;
    display: grid;
    gap: 12px;
  }

  @media (max-width: 960px) {
    .threat-map-heading,
    .threat-map-workspace,
    .threat-map-filterbar,
    .threat-map-filter-controls,
    .threat-map-notes,
    .threat-map-intel-grid {
      grid-template-columns: 1fr;
    }

    .threat-map-stage-caption,
    :global(.threat-map-detail-head) {
      display: grid;
      grid-template-columns: 1fr;
    }

    .threat-map-detail-stack {
      position: static;
    }
  }
</style>
