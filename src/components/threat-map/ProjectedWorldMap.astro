---
import { geoGraticule10, geoNaturalEarth1, geoPath } from 'd3-geo';
import { merge, mesh } from 'topojson-client';
import world from '../../data/world/countries-110m.json';

const projection = geoNaturalEarth1().fitExtent(
  [
    [34, 30],
    [966, 490],
  ],
  { type: 'Sphere' },
);

const pathBuilder = geoPath(projection);
const land = merge(world, world.objects.countries.geometries);
const borders = mesh(world, world.objects.countries, (a, b) => a !== b);
const graticule = geoGraticule10();

const spherePath = pathBuilder({ type: 'Sphere' }) ?? '';
const landPath = pathBuilder(land) ?? '';
const borderPath = pathBuilder(borders) ?? '';
const graticulePath = pathBuilder(graticule) ?? '';
---

<svg class="threat-map-backdrop projected-world-map" viewBox="0 0 1000 520" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
  <defs>
    <linearGradient id="tp-ocean-base" x1="8%" y1="2%" x2="86%" y2="100%">
      <stop offset="0%" stop-color="#13273d" />
      <stop offset="52%" stop-color="#0c1826" />
      <stop offset="100%" stop-color="#08111a" />
    </linearGradient>
    <radialGradient id="tp-atmosphere" cx="50%" cy="14%" r="78%">
      <stop offset="0%" stop-color="rgba(122, 192, 255, 0.18)" />
      <stop offset="42%" stop-color="rgba(122, 192, 255, 0.08)" />
      <stop offset="100%" stop-color="rgba(122, 192, 255, 0)" />
    </radialGradient>
    <radialGradient id="tp-stage-vignette" cx="50%" cy="50%" r="76%">
      <stop offset="64%" stop-color="rgba(8, 16, 24, 0)" />
      <stop offset="100%" stop-color="rgba(2, 5, 10, 0.48)" />
    </radialGradient>
    <linearGradient id="tp-land-fill" x1="8%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#5c7087" />
      <stop offset="54%" stop-color="#44586e" />
      <stop offset="100%" stop-color="#314457" />
    </linearGradient>
    <linearGradient id="tp-land-sheen" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="rgba(220, 234, 247, 0.24)" />
      <stop offset="50%" stop-color="rgba(184, 220, 250, 0.04)" />
      <stop offset="100%" stop-color="rgba(184, 220, 250, 0)" />
    </linearGradient>
    <filter id="tp-land-glow" x="-18%" y="-18%" width="136%" height="136%">
      <feGaussianBlur stdDeviation="2.8" result="blur" />
      <feMerge>
        <feMergeNode in="blur" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>

  <style>
    .projected-world-map .world-graticule {
      fill: none;
      stroke: rgba(160, 188, 214, 0.1);
      stroke-width: 0.85;
      stroke-dasharray: 2 10;
    }

    .projected-world-map .world-land-glow {
      fill: rgba(154, 201, 246, 0.08);
      stroke: rgba(154, 201, 246, 0.08);
      stroke-width: 5;
    }

    .projected-world-map .world-land {
      fill: url(#tp-land-fill);
      stroke: rgba(212, 228, 244, 0.18);
      stroke-width: 1;
      vector-effect: non-scaling-stroke;
    }

    .projected-world-map .world-land-sheen {
      fill: url(#tp-land-sheen);
      opacity: 0.7;
      mix-blend-mode: screen;
    }

    .projected-world-map .world-borders {
      fill: none;
      stroke: rgba(180, 204, 226, 0.15);
      stroke-width: 0.55;
      vector-effect: non-scaling-stroke;
    }
  </style>

  <rect x="0" y="0" width="1000" height="520" rx="28" fill="url(#tp-ocean-base)" />
  <path d={spherePath} fill="url(#tp-atmosphere)" opacity="0.95" />
  <path class="world-graticule" d={graticulePath} />
  <path class="world-land-glow" d={landPath} filter="url(#tp-land-glow)" />
  <path class="world-land" d={landPath} />
  <path class="world-land-sheen" d={landPath} />
  <path class="world-borders" d={borderPath} />
  <rect x="0" y="0" width="1000" height="520" rx="28" fill="url(#tp-stage-vignette)" />
</svg>
