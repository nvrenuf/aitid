---
import { buildDrawerSubtitle, shortModel } from '../../lib/dashboard-utils.js';
import { getThreatDetailHref } from '../../lib/threats-utils.js';

const { threat } = Astro.props;

const severityClasses = {
  critical: 'b-crit',
  high: 'b-high',
  medium: 'b-med',
  low: 'b-low',
  info: 'b-info',
};

const statusClasses = {
  active: 'b-high',
  investigating: 'b-med',
  mitigated: 'b-low',
  patched: 'b-low',
  disputed: 'b-gray',
};

const formatDate = (value) =>
  new Date(value).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<section class="page-panel threat-detail-shell">
  <div class="threat-detail-hero">
    <div class="page-copy">
      <span class="page-eyebrow">Canonical threat record</span>
      <div>
        <div class="page-kicker">Threat detail</div>
        <h1 class="page-headline">{threat.title}</h1>
      </div>
      <p>{threat.description}</p>

      <div class="tc-meta">
        <span class:list={['badge', severityClasses[threat.severity] ?? 'b-gray']}>{threat.severity.toUpperCase()}</span>
        <span class:list={['badge', statusClasses[threat.status] ?? 'b-gray']}>{threat.status}</span>
        <span class="badge b-gray">{threat.type}</span>
        {threat.cve ? <span class="ttp-tag">{threat.cve}</span> : null}
      </div>
    </div>

    <div class="threat-detail-hero-rail">
      <div class="drawer-score-card">
        <div class="drawer-label">Blended score</div>
        <span class="score">{threat.score.blended.toFixed(1)}</span>
      </div>

      <div class="info-card">
        <span>Review framing</span>
        <strong>{buildDrawerSubtitle(threat)}</strong>
        <p>This page is the canonical reference route for this tracked threat within the current product corpus.</p>
      </div>
    </div>
  </div>

  <div class="info-card-grid threat-detail-grid">
    <div class="info-card">
      <span>Published</span>
      <strong>{formatDate(threat.publishedAt)}</strong>
      <p>Last updated {formatDate(threat.updatedAt)}</p>
    </div>
    <div class="info-card">
      <span>Source</span>
      <strong>{threat.source}</strong>
      <p>Linked directly from the current corpus entry.</p>
    </div>
    <div class="info-card">
      <span>Patch posture</span>
      <strong>{threat.patchVersion ?? 'Patch not listed'}</strong>
      <p>{threat.affectedVersions ?? 'Affected versions are not explicitly listed in the current record.'}</p>
    </div>
    <div class="info-card">
      <span>Canonical route</span>
      <strong>{getThreatDetailHref(threat)}</strong>
      <p>Use this URL for direct review and internal linking instead of relying only on the overview drawer.</p>
    </div>
  </div>

  <div class="threat-detail-sections">
    <section class="threat-detail-section">
      <div class="page-kicker">Exposure coverage</div>
      <div class="threat-detail-bands">
        <div class="threat-detail-band">
          <strong>Models</strong>
          <div class="tc-meta">
            {threat.models.map((model) => <span class="badge b-model">{shortModel(model)}</span>)}
          </div>
        </div>
        <div class="threat-detail-band">
          <strong>Vectors and TTPs</strong>
          <div class="tc-meta">
            {threat.vectors.map((vector) => <span class="badge b-gray">{vector}</span>)}
            {threat.ttps.map((ttp) => <span class="ttp-tag">{ttp.id}</span>)}
          </div>
        </div>
      </div>
    </section>

    <section class="threat-detail-section">
      <div class="page-kicker">Operational notes</div>
      <div class="page-list">
        <div class="page-list-item">
          <strong>Severity rationale</strong>
          <p>{threat.score.rationale}</p>
        </div>
        <div class="page-list-item">
          <strong>Direct reference</strong>
          <p>
            {threat.sourceUrl ? <a class="drawer-link" href={threat.sourceUrl} target="_blank" rel="noreferrer">Open source advisory</a> : 'No direct source URL is available in the current dataset.'}
          </p>
        </div>
      </div>
    </section>

    <section class="threat-detail-section two-column">
      <div>
        <div class="page-kicker">Indicators and references</div>
        <div class="page-list">
          {threat.iocs.length ? threat.iocs.map((ioc) => (
            <div class="page-list-item">
              <strong>{ioc.type}: {ioc.value}</strong>
              <p>{ioc.context ?? 'No additional IOC context provided in the current record.'}</p>
            </div>
          )) : (
            <div class="page-list-item">
              <strong>No IOCs listed</strong>
              <p>The current corpus entry does not include indicators for this record.</p>
            </div>
          )}
        </div>
      </div>

      <div>
        <div class="page-kicker">Mitigation actions</div>
        <div class="page-list">
          {threat.mitigations.map((mitigation) => (
            <div class="page-list-item">
              <strong>Recommended action</strong>
              <p>{mitigation}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</section>

<style>
  .threat-detail-shell {
    display: grid;
    gap: 20px;
  }

  .threat-detail-hero {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.1fr) minmax(260px, 0.9fr);
  }

  .threat-detail-hero-rail,
  .threat-detail-sections,
  .threat-detail-section,
  .threat-detail-band {
    display: grid;
    gap: 14px;
  }

  .threat-detail-grid,
  .threat-detail-bands {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .threat-detail-band {
    border: 1px solid var(--border);
    border-radius: 16px;
    background: rgba(255,255,255,.02);
    padding: 16px;
  }

  .threat-detail-band strong {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--txt3);
  }

  .threat-detail-section.two-column {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  @media (max-width: 960px) {
    .threat-detail-hero,
    .threat-detail-grid,
    .threat-detail-bands,
    .threat-detail-section.two-column {
      grid-template-columns: 1fr;
    }
  }
</style>
