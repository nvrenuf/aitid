---
import { shortModel } from '../../lib/dashboard-utils.js';
import { THREAT_SORT_OPTIONS } from '../../lib/threats-utils.js';
import { formatEasternDate } from '../../lib/time.js';

const { threats, summary, filters } = Astro.props;

const initialThreats = JSON.stringify(threats);
---

<section class="page-panel threats-shell">
  <div class="threats-hero">
    <div class="page-copy">
      <span class="page-eyebrow">Threat corpus operations</span>
      <div>
        <div class="page-kicker">Threats</div>
        <h1 class="page-headline">Scan, filter, and prioritize the current ThreatParallax corpus.</h1>
      </div>
      <p>
        This route is for operator review, not executive summary. Search the tracked corpus, isolate the
        combinations that matter now, and sort by severity, score, or recency without pretending to be a
        full enterprise case-management surface.
      </p>
    </div>

    <div class="info-card-grid threats-kpis">
      <div class="info-card">
        <span>Tracked threats</span>
        <strong data-threat-total>{summary.total}</strong>
        <p>The current route works against the current product corpus only. No synthetic incidents are added here.</p>
      </div>
      <div class="info-card">
        <span>Active threats</span>
        <strong data-threat-active>{summary.activeCount}</strong>
        <p>Use status, vector, and model filters together to isolate the operational review queue.</p>
      </div>
      <div class="info-card">
        <span>Critical coverage</span>
        <strong data-threat-critical>{summary.criticalCount}</strong>
        <p>{summary.uniqueModels} tracked model families currently appear in the corpus.</p>
      </div>
    </div>
  </div>

  <div class="threats-workspace">
    <div class="threats-results-shell">
      <div class="threats-results-head">
        <div>
          <div class="page-kicker">Results</div>
          <h2><span data-results-count>{summary.total}</span> threats in scope</h2>
        </div>
        <div class="surface-chips" id="threats-active-filters">
          <span class="future-chip">All threats</span>
        </div>
      </div>

      <section class="threats-controls">
        <div class="threats-controls-head">
          <div>
            <div class="page-kicker">Operator workflow</div>
            <p class="threats-controls-copy">
              Filters sit directly above the corpus so search, scoping, and prioritization happen in the
              same visual lane as the feed.
            </p>
          </div>
          <div class="info-card threats-note">
            <span>Workflow guardrails</span>
            <p>
              Filters stay intentionally practical: severity, model, vector, status, and text search on
              the current data model only.
            </p>
          </div>
        </div>

        <div class="threats-filter-stack">
          <label class="threats-field threats-field-search">
            <span>Search corpus</span>
            <input
              id="threats-search"
              class="threats-input"
              type="search"
              placeholder="Search title, source, TTP, IOC, model, vector"
            />
          </label>

          <label class="threats-field">
            <span>Severity</span>
            <select id="threats-severity" class="threats-select">
              <option value="">All severities</option>
              {filters.severities.map((severity) => <option value={severity}>{severity}</option>)}
            </select>
          </label>

          <label class="threats-field">
            <span>Model</span>
            <select id="threats-model" class="threats-select">
              <option value="">All models</option>
              {
                filters.models.map((model) => (
                  <option value={model}>{shortModel(model)}</option>
                ))
              }
            </select>
          </label>

          <label class="threats-field">
            <span>Vector</span>
            <select id="threats-vector" class="threats-select">
              <option value="">All vectors</option>
              {filters.vectors.map((vector) => <option value={vector}>{vector}</option>)}
            </select>
          </label>

          <label class="threats-field">
            <span>Status</span>
            <select id="threats-status" class="threats-select">
              <option value="">All statuses</option>
              {filters.statuses.map((status) => <option value={status}>{status}</option>)}
            </select>
          </label>

          <label class="threats-field">
            <span>Sort</span>
            <select id="threats-sort" class="threats-select">
              {THREAT_SORT_OPTIONS.map((option) => <option value={option.value}>{option.label}</option>)}
            </select>
          </label>
        </div>
      </section>

      <div class="threats-results-meta">
        <div class="info-card">
          <span>Newest matching publication</span>
          <strong data-newest-published>{summary.newestPublishedAt ? formatEasternDate(summary.newestPublishedAt) : 'None'}</strong>
          <p>Sorting and counts update live as filters change. Search runs against the current in-product corpus.</p>
        </div>
      </div>

      <div id="threats-results" class="threats-results"></div>
      <script id="threats-corpus" type="application/json" set:html={initialThreats}></script>
    </div>
  </div>
</section>

<script>
  import '../../scripts/threats-client.js';
</script>

<style>
  .threats-shell {
    display: grid;
    gap: 20px;
  }

  .threats-hero {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.9fr);
  }

  .threats-kpis {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .threats-workspace {
    display: grid;
    gap: 18px;
  }

  .threats-controls,
  .threats-results-shell {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.02);
  }

  .threats-controls {
    padding: 18px;
    display: grid;
    gap: 18px;
    background:
      linear-gradient(180deg, rgba(125, 196, 255, 0.08), rgba(125, 196, 255, 0.02)),
      rgba(255, 255, 255, 0.02);
  }

  .threats-controls-head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: start;
  }

  .threats-controls-copy {
    margin-top: 8px;
    max-width: 58ch;
    color: var(--txt2);
    font-size: 13px;
    line-height: 1.65;
  }

  .threats-filter-stack {
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(0, 1.8fr) repeat(5, minmax(0, 1fr));
    align-items: end;
  }

  .threats-field-search {
    grid-column: span 1;
  }

  .threats-field {
    display: grid;
    gap: 8px;
    font-size: 12px;
    color: var(--txt2);
    font-weight: 700;
  }

  .threats-input,
  .threats-select {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
    color: var(--txt);
    padding: 11px 13px;
    font: inherit;
  }

  .threats-input::placeholder {
    color: var(--txt3);
  }

  .threats-results-shell {
    padding: 20px;
    display: grid;
    gap: 16px;
  }

  .threats-results-head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: start;
  }

  .threats-results-head h2 {
    font-size: clamp(24px, 2.8vw, 34px);
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .threats-results-meta {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
  }

  .threats-results {
    display: grid;
    gap: 14px;
  }

  .threat-row {
    padding: 18px;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
    display: grid;
    gap: 14px;
  }

  .threat-row-eyebrow {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: start;
    flex-wrap: wrap;
  }

  .threat-row-head,
  .threat-row-meta,
  .threat-row-foot {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: start;
    flex-wrap: wrap;
  }

  .threat-row-title {
    font-size: 22px;
    line-height: 1.1;
    max-width: 24ch;
  }

  .threat-row-link {
    color: inherit;
    text-decoration: none;
  }

  .threat-row-link:hover {
    color: var(--info);
  }

  .threat-row-summary {
    color: var(--txt2);
    font-size: 13px;
    line-height: 1.65;
  }

  .threat-row-scan {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .threat-row-scan-item {
    border: 1px solid var(--border);
    border-radius: 14px;
    background: rgba(255,255,255,.025);
    padding: 12px 13px;
    display: grid;
    gap: 6px;
    min-height: 84px;
  }

  .threat-row-scan-item span {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--txt3);
    font-weight: 700;
  }

  .threat-row-scan-item strong {
    font-size: 15px;
    line-height: 1.25;
    color: var(--txt);
  }

  .threat-row-scan-item p {
    color: var(--txt2);
    font-size: 12px;
    line-height: 1.5;
  }

  .threat-row-groups {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .threat-row-band {
    border: 1px solid var(--border);
    border-radius: 14px;
    background: rgba(255,255,255,.02);
    padding: 14px;
    display: grid;
    gap: 10px;
  }

  .threat-row-band strong {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--txt3);
  }

  .threat-row-foot {
    font-size: 12px;
    color: var(--txt3);
  }

  .threat-row-source {
    color: var(--txt2);
    font-weight: 700;
  }

  .threat-row-date {
    color: var(--txt3);
    font-size: 12px;
    line-height: 1.5;
    text-align: right;
  }

  .threats-note {
    min-width: min(320px, 100%);
    max-width: 360px;
  }

  .threat-empty {
    padding: 28px;
    border: 1px dashed var(--border);
    border-radius: 18px;
    color: var(--txt2);
    line-height: 1.65;
    background: rgba(255,255,255,.02);
  }

  @media (max-width: 960px) {
    .threats-hero,
    .threats-workspace {
      grid-template-columns: 1fr;
    }

    .threats-controls-head,
    .threat-row-scan {
      grid-template-columns: 1fr;
      display: grid;
    }

    .threats-filter-stack {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .threats-field-search {
      grid-column: 1 / -1;
    }

    .threats-kpis,
    .threat-row-groups {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .threats-filter-stack {
      grid-template-columns: 1fr;
    }

    .threat-row-date {
      text-align: left;
    }
  }
</style>
