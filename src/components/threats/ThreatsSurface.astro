---
import { shortModel } from '../../lib/dashboard-utils.js';
import { THREAT_SORT_OPTIONS } from '../../lib/threats-utils.js';
import { formatEasternDate } from '../../lib/time.js';

const { threats, summary, filters } = Astro.props;

const initialThreats = JSON.stringify(threats);
---

<section class="page-panel threats-shell">
  <div class="threats-hero">
    <div class="page-copy">
      <span class="page-eyebrow">Threat corpus operations</span>
      <div>
        <div class="page-kicker">Threats</div>
        <h1 class="page-headline">Operator scanning across the current ThreatParallax corpus.</h1>
      </div>
      <p>Search, scope, and prioritize the current record set from one restrained workbench.</p>
    </div>

    <div class="info-card-grid threats-kpis">
      <div class="info-card">
        <span>Tracked threats</span>
        <strong data-threat-total>{summary.total}</strong>
        <p>Current corpus only.</p>
      </div>
      <div class="info-card">
        <span>Active threats</span>
        <strong data-threat-active>{summary.activeCount}</strong>
        <p>Immediate review queue.</p>
      </div>
      <div class="info-card">
        <span>Critical coverage</span>
        <strong data-threat-critical>{summary.criticalCount}</strong>
        <p>{summary.uniqueModels} model families in scope.</p>
      </div>
    </div>
  </div>

  <div class="threats-workspace">
    <div class="threats-results-shell">
      <section class="threats-controls">
        <div class="threats-controls-head">
          <div>
            <div class="page-kicker">Workbench</div>
            <h2><span data-results-count>{summary.total}</span> threats in scope</h2>
          </div>
          <div class="surface-chips threats-active-filters" id="threats-active-filters">
            <span class="future-chip">All threats</span>
          </div>
        </div>

        <div class="threats-filter-stack">
          <label class="threats-field threats-field-search">
            <span>Search corpus</span>
            <input
              id="threats-search"
              class="threats-input"
              type="search"
              placeholder="Search title, source, TTP, IOC, model, vector"
            />
          </label>

          <label class="threats-field">
            <span>Severity</span>
            <select id="threats-severity" class="threats-select">
              <option value="">All severities</option>
              {filters.severities.map((severity) => <option value={severity}>{severity}</option>)}
            </select>
          </label>

          <label class="threats-field">
            <span>Model</span>
            <select id="threats-model" class="threats-select">
              <option value="">All models</option>
              {filters.models.map((model) => <option value={model}>{shortModel(model)}</option>)}
            </select>
          </label>

          <label class="threats-field">
            <span>Vector</span>
            <select id="threats-vector" class="threats-select">
              <option value="">All vectors</option>
              {filters.vectors.map((vector) => <option value={vector}>{vector}</option>)}
            </select>
          </label>

          <label class="threats-field">
            <span>Status</span>
            <select id="threats-status" class="threats-select">
              <option value="">All statuses</option>
              {filters.statuses.map((status) => <option value={status}>{status}</option>)}
            </select>
          </label>

          <label class="threats-field">
            <span>Sort</span>
            <select id="threats-sort" class="threats-select">
              {THREAT_SORT_OPTIONS.map((option) => <option value={option.value}>{option.label}</option>)}
            </select>
          </label>

          <button type="button" class="expand-btn threats-reset" id="threats-reset">Clear</button>
        </div>
      </section>

      <div class="threats-results-meta">
        <div class="info-card">
          <span>Newest matching publication</span>
          <strong data-newest-published>{summary.newestPublishedAt ? formatEasternDate(summary.newestPublishedAt) : 'None'}</strong>
          <p>Counts and ordering update live as filters change.</p>
        </div>
      </div>

      <div id="threats-results" class="threats-results"></div>
      <script id="threats-corpus" type="application/json" set:html={initialThreats}></script>
    </div>
  </div>
</section>

<script>
  import '../../scripts/threats-client.js';
</script>

<style>
  .threats-shell,
  .threats-workspace,
  .threats-results-shell,
  .threats-results {
    display: grid;
    gap: 16px;
  }

  .threats-hero {
    display: grid;
    gap: 18px;
    grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.9fr);
    align-items: end;
  }

  .threats-kpis {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .threats-results-shell {
    padding: 18px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.015));
  }

  .threats-controls {
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 18px;
    display: grid;
    gap: 14px;
    background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.015));
  }

  .threats-controls-head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: start;
  }

  .threats-controls-head h2 {
    margin-top: 8px;
    font-family: var(--font-display);
    font-size: clamp(24px, 2.4vw, 32px);
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  .threats-active-filters {
    justify-content: flex-end;
    max-width: 360px;
  }

  .threats-filter-stack {
    display: grid;
    gap: 10px;
    grid-template-columns: minmax(0, 1.8fr) repeat(5, minmax(0, 1fr)) auto;
    align-items: end;
  }

  .threats-field {
    display: grid;
    gap: 8px;
    font-size: 12px;
    color: var(--txt2);
    font-weight: 700;
  }

  .threats-input,
  .threats-select {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: rgba(255,255,255,.03);
    color: var(--txt);
    padding: 12px 13px;
    font: inherit;
  }

  .threats-input::placeholder {
    color: var(--txt3);
  }

  .threats-reset {
    height: 46px;
    white-space: nowrap;
  }

  .threat-row {
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(255,255,255,.035), rgba(255,255,255,.018));
    display: grid;
    gap: 12px;
  }

  .threat-row-top,
  .threat-row-main,
  .threat-row-foot {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: start;
    flex-wrap: wrap;
  }

  .threat-row-date {
    color: var(--txt3);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .threat-row-title {
    font-size: 20px;
    line-height: 1.08;
    max-width: 28ch;
  }

  .threat-row-link {
    color: inherit;
    text-decoration: none;
  }

  .threat-row-link:hover {
    color: var(--info);
  }

  .threat-row-source,
  .threat-row-meta-line,
  .threat-row-summary,
  .threat-row-foot {
    color: var(--txt2);
  }

  .threat-row-source {
    margin-top: 8px;
    font-weight: 700;
  }

  .threat-row-meta-line {
    margin-top: 6px;
    font-size: 12px;
    line-height: 1.5;
  }

  .threat-row-summary {
    font-size: 13px;
    line-height: 1.6;
    max-width: 82ch;
  }

  .threat-row-score {
    min-width: 110px;
    padding: 11px 12px;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: rgba(7,16,24,.5);
    text-align: right;
  }

  .threat-row-score-label {
    display: block;
    margin-bottom: 6px;
    color: var(--txt3);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
  }

  .threat-row-score-value {
    font-family: var(--font-display);
    font-size: 26px;
    line-height: 0.92;
    letter-spacing: -0.05em;
  }

  .threat-row-bands {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .threat-row-band {
    border: 1px solid var(--border);
    border-radius: 14px;
    background: rgba(255,255,255,.025);
    padding: 12px 13px;
    display: grid;
    gap: 8px;
  }

  .threat-row-band strong {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--txt3);
    font-weight: 700;
  }

  .threat-row-foot {
    padding-top: 12px;
    border-top: 1px solid rgba(145,169,201,.14);
    font-size: 12px;
    line-height: 1.5;
  }

  .threat-empty {
    padding: 28px;
    border: 1px dashed var(--border);
    border-radius: 18px;
    color: var(--txt2);
    line-height: 1.65;
    background: rgba(255,255,255,.02);
  }

  @media (max-width: 1280px) {
    .threats-hero {
      grid-template-columns: 1fr;
    }

    .threats-controls-head {
      display: grid;
    }

    .threats-active-filters {
      justify-content: flex-start;
      max-width: none;
    }

    .threats-filter-stack {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .threats-field-search {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 960px) {
    .threats-hero,
    .threats-controls-head,
    .threats-filter-stack,
    .threats-kpis,
    .threat-row-bands {
      grid-template-columns: 1fr;
      display: grid;
    }

    .threats-active-filters {
      justify-content: flex-start;
      max-width: none;
    }
  }
</style>
